{
  "name": "sentinel-ai",
  "version": "1.0.0",
  "description": "Sentinel AI — Autonomous financial intelligence platform for deep market research.",
  "author": "Rajkaran Yadav",
  "type": "module",
  "main": "src/interface/index.tsx",
  "bin": {
    "sentinel": "./src/interface/index.tsx"
  },
  "scripts": {
    "start": "bun run src/interface/index.tsx",
    "dev": "bun --watch run src/interface/index.tsx",
    "gateway": "tsx src/services/gateway/index.ts run",
    "gateway:login": "tsx src/services/gateway/index.ts login",
    "serve": "tsx src/services/api/server.ts",
    "serve:dev": "tsx watch src/services/api/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@langchain/anthropic": "^1.3.25",
    "@langchain/core": "^1.1.36",
    "@langchain/exa": "^1.0.1",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.3.1",
    "@langchain/tavily": "^1.2.0",
    "@mariozechner/pi-tui": "^0.52.12",
    "@mozilla/readability": "^0.6.0",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "better-sqlite3": "^12.8.0",
    "croner": "^9.1.0",
    "diff": "^8.0.4",
    "dotenv": "^17.3.1",
    "exa-js": "^2.10.1",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.10",
    "langsmith": "^0.4.12",
    "linkedom": "^0.18.12",
    "pg": "^8.20.0",
    "playwright": "^1.58.2",
    "qrcode-terminal": "^0.12.0",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.28.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/jest": "^29.5.14",
    "@types/pg": "^8.20.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/socket.io": "^3.0.1",
    "@types/stack-utils": "^2.0.3",
    "babel-jest": "^30.3.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
